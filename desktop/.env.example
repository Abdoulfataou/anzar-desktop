# ============================================================================
# ANZAR — Configuration
# ============================================================================
# Copie ce fichier en .env et configure le backend.
#
# ⚠️  SÉCURITÉ: Les clés API (DeepSeek, Kimi) sont stockées UNIQUEMENT
# sur le serveur backend. Elles ne doivent JAMAIS être dans ce fichier
# ni dans le code client.
# ============================================================================

# ─── Backend ANZAR (obligatoire) ───
# URL du serveur backend qui gère les clés API et le proxy IA
VITE_BACKEND_URL=http://localhost:8000

# ─── Mode de fonctionnement ───
# "production" = backend obligatoire (défaut, recommandé)
# "development" = mode dev avec logs supplémentaires
VITE_APP_MODE=production

# ─── Observabilité (Sentry) ───
# DSN public Sentry (côté frontend). Laisse vide pour désactiver.
VITE_SENTRY_DSN=

# Optionnel: échantillonnage tracing (0.0 - 1.0). Défaut: 0.1
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
