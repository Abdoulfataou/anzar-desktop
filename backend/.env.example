# ============================================================================
# ANZAR Backend — Configuration serveur
# ============================================================================
# Copie ce fichier en .env et remplis tes clés API.
# ⚠️  Ces clés restent UNIQUEMENT sur le serveur. JAMAIS côté client.
# ============================================================================

# ─── Clés API (obligatoire) ───
DEEPSEEK_API_KEY=sk-xxx
KIMI_API_KEY=sk-xxx
# Serper: recherche Google pour le chat IA (2500 gratuits → serper.dev)
SERPER_API_KEY=

# ─── Email (Brevo — ex Sendinblue) ───
# Clé API Brevo: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-xxx
SENDER_EMAIL=noreply@anzar.app
SENDER_NAME=ANZAR
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# ─── URLs API ───
DEEPSEEK_BASE_URL=https://api.deepseek.com
KIMI_BASE_URL=https://api.moonshot.cn

# ─── Serveur ───
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
# Railway injecte PORT automatiquement — pas besoin de le définir

# ─── Sécurité ───
# OBLIGATOIRE en production: openssl rand -hex 32
JWT_SECRET=CHANGE-ME-IN-PRODUCTION
JWT_EXPIRY_HOURS=72

# Origines CORS autorisées (séparées par virgules)
# Ajouter le domaine Tauri de ton app desktop
CORS_ORIGINS=http://localhost:1420,tauri://localhost,https://ton-app.railway.app

# Rate limiting
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_DAY=500

# ─── Base de données ───
DATABASE_PATH=./data/anzar.db

# ─── Modèles IA ───
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REASONER=deepseek-reasoner
KIMI_MODEL=moonshot-v1-8k

# ─── Pricing — PRIX DE VENTE (FCFA par 1M tokens, facturés aux utilisateurs) ───
# DeepSeek V4-Flash: coût réel 78/157 F → vente avec marge x3
DEEPSEEK_INPUT_COST_PER_MILLION=250
DEEPSEEK_OUTPUT_COST_PER_MILLION=500
# Kimi K2.5: coût réel 336/1400 F → vente avec marge x3
KIMI_INPUT_COST_PER_MILLION=1000
KIMI_OUTPUT_COST_PER_MILLION=4000
USD_TO_FCFA=560

# Bonus recharge progressif (seuil_FCFA:bonus_%, séparés par virgules)
RECHARGE_BONUS_TIERS=5000:15,15000:25,50000:35

# ─── Mode ───
LOG_LEVEL=info
DEBUG=false
